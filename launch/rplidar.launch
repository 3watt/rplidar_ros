<launch>
  <arg name="min_distance"            default="0.15"/>

  <node name="rplidarNode"          pkg="rplidar_ros"  type="rplidarNode" output="screen">
    <param name="serial_port"         type="string" value="/dev/ttyUSB0"/>
    <param name="serial_baudrate"     type="int"    value="115200"/><!--A1/A2 -->
    <!--param name="serial_baudrate"     type="int"    value="256000"--><!--A3 -->
    <param name="frame_id"            type="string" value="laser"/>
    <param name="inverted"            type="bool"   value="false"/>
    <param name="angle_compensate"    type="bool"   value="true"/>
    <param name="scan_range"    type="bool"   value="true"/>
    <param name="min_distance"  value="$(arg min_distance)"/>
  </node>

  <!-- <node pkg="tf" type="static_transform_publisher" name="laser" args="0 0 0.4 3.14 0 0  base_link laser 60"/> -->
</launch>
